# ChengbookTTS 环境变量配置模板
# 复制此文件为 .env 并修改

# ====== 模型选择 ======
# 可选: cosyvoice3 | soulxpodcast | indextts_v1 | indextts_v2 | auto
MODEL_TYPE=cosyvoice3

# ====== 服务配置 ======
HOST=0.0.0.0
PORT=8080
API_KEY=

# ====== 并发控制 ======
MAX_CONCURRENT=1

# ====== 文本预处理 ======
TEXT_PREPROCESS=1
TEXT_SEGMENT=1

# ====== 加速选项 ======
FP16=1
LOAD_TRT=0

# ====== 自定义音色 ======
MAX_CUSTOM_VOICES=20

# ====== 模型路径（可选，覆盖 YAML 配置）======
# COSYVOICE3_MODEL_DIR=
# SOULXPODCAST_MODEL_DIR=
# INDEXTTS_V1_MODEL_DIR=
# INDEXTTS_V2_MODEL_DIR=
